# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=hcak_soat_api

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=hcak-soat-videos
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/video-processing-queue

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# AWS Cognito (for Auth Lambda integration)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxxxxx
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_REGION=us-east-1

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_key_here
SENDER_EMAIL=noreply@hcaksoat.com

# Application
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug